# Copy this file to .env and adjust values for local development.
# Production values are set in the Cloudflare Pages dashboard.
# All VITE_ variables are baked into the static bundle at build time.

# Milliseconds of inactivity before the kiosk auto-returns to the Welcome screen (300000 = 5 min).
VITE_IDLE_TIMEOUT_MS=3000000

# Milliseconds the Results screen lingers before auto-returning to Welcome.
VITE_RESULTS_LINGER_MS=3000000
